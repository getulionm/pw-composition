{
  "name": "pw-framework-example",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "playwright install chromium",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:outlined": "cross-env POM_VISUAL=1 playwright test",
    "test:outlined:headed": "cross-env POM_VISUAL=1 playwright test --headed",
    "test:outlined:ui": "cross-env POM_VISUAL=1 playwright test --ui",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build:mock": "node scripts/copy-readme-to-mock.mjs",
    "prestart:mock": "npm run build:mock",
    "prestart:mock:outlined": "npm run build:mock",
    "start:mock": "npx http-server mock-app -p 4173 -c-1",
    "start:mock:outlined": "npx http-server mock-app -p 4173 -c-1 -o /?pom=1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.8.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-boundaries": "^5.0.0",
    "http-server": "^14.1.1",
    "typescript": "^5.5.0"
  }
}
